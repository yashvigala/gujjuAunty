# Convex deployment URL — copy from packages/backend/.env.local (CONVEX_URL)
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# Razorpay Key ID (test mode starts with rzp_test_). Public by design — it is
# sent to the browser to open the checkout popup.
# The Key SECRET is never stored here; set it on the Convex deployment instead:
#   cd packages/backend && npx convex env set RAZORPAY_KEY_SECRET "<secret>"
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_<your-key-id>
